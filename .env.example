# ──────────────────────────────────────────────
# Nickel&Dime Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored; never commit it.
# ──────────────────────────────────────────────

# ── Flask ──
FLASK_ENV=dev
FLASK_SECRET=change-me-to-something-random

# ── Database ──
# Dev uses SQLite by default. Set for production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/nickeldime

# ── Stripe Billing ──
# Dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring $10/mo product in Stripe, then paste its Price ID:
STRIPE_PRO_PRICE_ID=price_...

# ── Market Data APIs ──

# FRED API key (Federal Reserve economic data). Free.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Email (password resets) ──
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@nickeldime.io
