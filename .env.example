# ──────────────────────────────────────────────
# Nickel&Dime Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored; never commit it.
# ──────────────────────────────────────────────

# ── Flask ──
# Options: dev | staging | prod | test
FLASK_ENV=dev
FLASK_SECRET=change-me-to-something-random

# ── Admin ──
# Comma-separated list of admin emails (permanent Pro, no trial expiry)
ADMIN_EMAILS=crb1898@gmail.com

# ── Database ──
# Dev uses SQLite by default. Set for production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/nickelanddime

# ── Stripe Billing ──
# Dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring $10/mo product in Stripe, then paste its Price ID:
STRIPE_PRO_PRICE_ID=price_...

# ── Market Data APIs ──

# FRED API key (Federal Reserve economic data). Free.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinMarketCap API key (crypto Fear & Greed). Free tier at:
# https://pro.coinmarketcap.com/
CMC_API_KEY=

# ── OpenAI (AI Portfolio Advisor — Pro feature) ──
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Plaid (brokerage & bank linking) ──
# Sign up at https://dashboard.plaid.com/
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox
# Optional webhook URL for real-time updates (e.g. https://nickelanddime.io/api/plaid/webhook)
# PLAID_WEBHOOK_URL=

# ── Encryption ──
# Fernet key for encrypting secrets at rest (Coinbase API keys, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Email (password resets) ──
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@nickelanddime.io
